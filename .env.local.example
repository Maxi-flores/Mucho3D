# Firebase Configuration
# Get these values from Firebase Console: https://console.firebase.google.com/
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Analytics (can be empty)
VITE_FIREBASE_MEASUREMENT_ID=

# Local Services (for Phase 4)
VITE_OLLAMA_URL=http://localhost:11434
VITE_BLENDER_SOCKET=http://localhost:7860

# Copy this file to .env.local and fill in your Firebase credentials
# .env.local should NOT be committed to git
