# Proxy Server Configuration

# Ollama settings
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:latest

# MCP Bridge (Model Context Protocol)
MCP_BRIDGE_URL=http://localhost:3001

# Proxy server
PORT=8787

# Blender execution mode
# mock: simulated execution (for testing, no Blender required)
# local: connects to local Blender via MCP bridge
BLENDER_MODE=local

# Blender bridge connection
BLENDER_BRIDGE_HOST=127.0.0.1
BLENDER_BRIDGE_PORT=9100
BLENDER_BRIDGE_TIMEOUT_MS=30000

# Job processing
JOB_POLLING_INTERVAL_MS=1000
JOB_TIMEOUT_MS=300000

# Output directory for generated files
BLENDER_OUTPUT_DIR=./outputs

# Firebase Configuration (for Firestore job persistence)
# Option 1: Use service account key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# Option 2: Use individual environment variables
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY=your-private-key
# FIREBASE_CLIENT_EMAIL=your-service-account-email@project.iam.gserviceaccount.com

# If neither is set, jobs will be stored in memory only (lost on server restart)
