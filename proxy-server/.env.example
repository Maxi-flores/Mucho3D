# Proxy Server Configuration

# Ollama settings
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:latest

# MCP Bridge (Model Context Protocol)
MCP_BRIDGE_URL=http://localhost:3001

# Proxy server
PORT=8787

# Blender execution mode
# mock: simulated execution (for testing, no Blender required)
# local: connects to local Blender via MCP bridge
BLENDER_MODE=local

# Blender bridge connection
BLENDER_BRIDGE_HOST=127.0.0.1
BLENDER_BRIDGE_PORT=9100
BLENDER_BRIDGE_TIMEOUT_MS=30000

# Job processing
JOB_POLLING_INTERVAL_MS=1000
JOB_TIMEOUT_MS=300000

# Output directory for generated files
BLENDER_OUTPUT_DIR=./outputs
