# Mucho3D Environment Configuration
# Copy this file to .env and fill in your values

# ==============================================
# Firebase Configuration
# ==============================================
# Get these from your Firebase project settings:
# https://console.firebase.google.com/project/YOUR_PROJECT/settings/general
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=G-your_measurement_id

# ==============================================
# Service URLs (Local Development)
# ==============================================
# Ollama AI Server (for plan generation)
OLLAMA_URL=http://localhost:11434

# MCP Bridge URL (tool registry and execution)
MCP_BRIDGE_URL=http://localhost:8790

# Blender Worker URL (3D rendering)
BLENDER_WORKER_URL=http://localhost:8788

# Frontend URL (for generating scene links)
FRONTEND_URL=http://localhost:5173

# Proxy Server URL (main API gateway)
PROXY_SERVER_URL=http://localhost:8787

# ==============================================
# WhatsApp Configuration
# ==============================================
# Admin phone number in WhatsApp format: 1234567890@c.us
# This is optional - used for admin-only features
WHATSAPP_ADMIN_PHONE=

# WhatsApp Gateway Port
WHATSAPP_GATEWAY_PORT=8791

# ==============================================
# Server Ports
# ==============================================
# Frontend (Vite dev server)
VITE_PORT=5173

# Proxy Server (Express)
PORT=8787

# MCP Bridge (Express)
MCP_BRIDGE_PORT=8790

# Blender Worker (FastAPI)
BLENDER_WORKER_PORT=8788

# ==============================================
# Blender Worker Configuration
# ==============================================
# Directory where exported 3D files are saved
BLENDER_WORKER_EXPORT_DIR=./apps/blender-worker/exports

# Directory where viewport snapshots are saved
BLENDER_WORKER_SNAPSHOT_DIR=./apps/blender-worker/snapshots

# ==============================================
# Development Settings
# ==============================================
# Set to 'development' for local dev, 'production' for deployed
NODE_ENV=development

# Enable debug logging
DEBUG=mucho3d:*
