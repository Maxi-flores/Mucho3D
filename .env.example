# Mucho3D V3 Environment Variables

# Local-first configuration.
# The Vite frontend runs on http://127.0.0.1:5173 and does not require any cloud services.

# Ollama AI Service
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=qwen2.5-coder:latest

# Proxy Server (Node.js gateway between frontend and Ollama)
VITE_PROXY_API_URL=http://localhost:8787

# MCP Bridge (configured on the proxy server; frontend calls it through VITE_PROXY_API_URL)
VITE_ENABLE_MCP_BRIDGE=true

# Blender Integration
VITE_BLENDER_BRIDGE_URL=http://localhost:7860

# Optional local API configuration
VITE_API_BASE_URL=http://127.0.0.1:3001
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_AI_CHAT=true
VITE_ENABLE_3D_STUDIO=true

# Firebase Configuration (optional - for auth and data persistence)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Analytics (optional)
VITE_ANALYTICS_ID=

# Sentry (optional)
VITE_SENTRY_DSN=

# Environment
VITE_ENV=development
