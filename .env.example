# Mucho3D V2 Environment Variables

# Local-first configuration.
# The Vite frontend runs on http://127.0.0.1:3000 and does not require any cloud services.

# Optional local API configuration
VITE_API_BASE_URL=http://127.0.0.1:3001
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_AI_CHAT=false
VITE_ENABLE_3D_STUDIO=true
VITE_ENABLE_SHOP=true

# Analytics (optional)
VITE_ANALYTICS_ID=

# Sentry (optional)
VITE_SENTRY_DSN=

# Environment
VITE_ENV=development
